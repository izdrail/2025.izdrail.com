---
const services = [
  {
    title: "Senior Backend Engineer for Hire",
    description: "Building robust, scalable server-side systems that power your business applications. Specializing in high-performance APIs, microservices architecture, and cloud-native solutions.",
    keywords: ["Senior Backend Engineer for hire", "Backend Developer", "Server-side Development"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.5em" height="2.5em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
  },
  {
    title: "Freelance Full Stack Developer",
    description: "End-to-end development services for web and mobile applications. From database design to responsive frontend interfaces, I deliver complete solutions that work seamlessly across all platforms.",
    keywords: ["Freelance Full Stack Developer", "Full Stack Engineer", "Web Developer"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.5em" height="2.5em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`
  },
  {
    title: "Scalable Systems Consultant",
    description: "Architecture consulting for systems designed to grow. I help businesses design and implement scalable infrastructures that handle increased load without performance degradation.",
    keywords: ["Scalable Systems Consultant", "System Architecture", "Scalability Consulting"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.5em" height="2.5em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`
  },
  {
    title: "Custom Software Development Services",
    description: "Tailored software solutions built to address your unique business challenges. From concept to deployment, I create custom applications that streamline operations and drive growth.",
    keywords: ["Custom Software Development Services", "Software Development", "Custom Software"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.5em" height="2.5em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
  },
  {
    title: "AI Automation Expert",
    description: "Transform your business processes with intelligent automation. I develop AI-powered solutions including custom LLMs, AI agents, and workflow automation systems that reduce manual effort and increase efficiency.",
    keywords: ["AI Automation Expert", "AI Automation", "AI Agent Development", "LLM Implementation"],
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="2.5em" height="2.5em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M12 2a10 10 0 0 1 10 10h-10V2z"/><path d="M12 12l-7.5 7.5"/><circle cx="12" cy="12" r="2"/></svg>`
  }
];
---

<section class="text-[var(--white)] py-12" id="services">
  <div class="max-w-5xl mx-auto space-y-8">
    <div class="text-left space-y-4">
      <h2 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-4">
        Services
      </h2>
      <p class="text-lg text-[var(--white-icon)] max-w-3xl">
        Professional software engineering services tailored to help your business grow. 
        Whether you need a senior backend engineer for hire, a freelance full stack developer, 
        or an AI automation expert, I deliver solutions that drive results.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {services.map((service) => (
        <div class="p-6 bg-[#1414149c] rounded-2xl border border-[var(--white-icon-tr)] hover:border-[var(--sec)] transition-colors duration-300">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-[var(--sec)]" set:html={service.icon} />
            <h3 class="text-xl font-semibold text-[var(--white)]">
              {service.title}
            </h3>
          </div>
          <p class="text-[var(--white-icon)] mb-4 leading-relaxed">
            {service.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {service.keywords.map((keyword) => (
              <span class="text-xs px-3 py-1 rounded-full bg-[var(--white-icon-tr)] text-[var(--white-icon)]">
                {keyword}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 p-6 bg-[var(--sec)] bg-opacity-10 rounded-2xl border border-[var(--sec)]">
      <h3 class="text-xl font-semibold text-[var(--white)] mb-3">
        Ready to Work Together?
      </h3>
      <p class="text-[var(--white-icon)] mb-4">
        I'm currently available for freelance projects and consulting engagements. 
        Whether you need a senior backend engineer for hire or full stack development services, 
        let's discuss how I can help bring your project to life.
      </p>
      <a 
        href="#contact" 
        class="inline-block px-6 py-3 bg-[var(--sec)] text-white font-medium rounded-xl hover:bg-opacity-90 transition duration-300"
      >
        Get in Touch
      </a>
    </div>

    <!-- FAQ Section for GEO/AI Overviews -->
    <div class="mt-12 space-y-6">
      <h2 class="text-3xl md:text-4xl font-medium text-[var(--white)]">
        Frequently Asked Questions
      </h2>
      
      <div class="space-y-4">
        <details class="group bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)]">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[var(--white)] font-medium">
            <span>What services does Stefan Bogdanel offer?</span>
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-[var(--white-icon)] px-6 pb-6 pt-0 leading-relaxed">
            Stefan Bogdanel offers Senior Backend Engineering, Freelance Full Stack Development, Scalable Systems Consulting, Custom Software Development, and AI Automation services. He specializes in PHP, Laravel, JavaScript, TypeScript, Go, Python, React, Vue.js, Node.js, Docker, Kubernetes, AWS, PostgreSQL, MySQL, and Redis.
          </div>
        </details>

        <details class="group bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)]">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[var(--white)] font-medium">
            <span>How much does a senior backend engineer cost?</span>
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-[var(--white-icon)] px-6 pb-6 pt-0 leading-relaxed">
            As a freelance senior backend engineer, Stefan offers competitive rates for custom software development. Contact him for a personalized quote based on your specific project requirements, scope, and timeline.
          </div>
        </details>

        <details class="group bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)]">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[var(--white)] font-medium">
            <span>What industries does Stefan Bogdanel work with?</span>
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-[var(--white-icon)] px-6 pb-6 pt-0 leading-relaxed">
            Stefan has experience building solutions for enterprise software, e-commerce applications, CRM systems, IoT and LoRaWAN devices, AI and LLM infrastructure. He works with both public and private organizations across various sectors.
          </div>
        </details>

        <details class="group bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)]">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[var(--white)] font-medium">
            <span>What is AI automation and how can it help my business?</span>
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-[var(--white-icon)] px-6 pb-6 pt-0 leading-relaxed">
            AI automation uses artificial intelligence to streamline business processes, reduce manual work, and increase efficiency. Stefan develops custom Large Language Models, AI agents, and workflow automation systems tailored to your specific business needs.
          </div>
        </details>

        <details class="group bg-[#1414149c] rounded-xl border border-[var(--white-icon-tr)]">
          <summary class="flex justify-between items-center p-6 cursor-pointer list-none text-[var(--white)] font-medium">
            <span>How do I hire a senior software engineer?</span>
            <span class="transition group-open:rotate-180">
              <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
            </span>
          </summary>
          <div class="text-[var(--white-icon)] px-6 pb-6 pt-0 leading-relaxed">
            To hire a senior software engineer, you can contact Stefan Bogdanel via email at stefan@izdrail.com or through the contact form on his website. He's available for freelance projects and consulting engagements worldwide.
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

---
interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title,
  description = "Senior Backend Engineer for hire. Freelance Full Stack Developer & Scalable Systems Consultant. Expert in Custom Software Development & AI Automation. Building software since 2010.",
  image = "/og-image.png",
  url = Astro.url.href,
} = Astro.props;

const canonicalURL = new URL(
  Astro.url.pathname,
  Astro.site || "https://izdrail.com",
);
const fullTitle =
  title === "izdrail.com"
    ? "Senior Software Engineer - Stefan Bogdanel"
    : `${title} - Stefan Bogdanel`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Stefan Bogdanel" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- OpenGraph Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content={new URL(image, Astro.site || "https://izdrail.com").href}
    />
    <meta
      property="og:site_name"
      content="Stefan Bogdanel - Senior Software Engineer"
    />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={url} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={new URL(image, Astro.site || "https://izdrail.com").href}
    />
    <meta name="twitter:creator" content="@izdrail" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Preconnect to critical domains -->
    <link
      rel="preconnect"
      href="https://www.googletagmanager.com"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://static.hotjar.com" crossorigin />
    <link rel="preconnect" href="https://cdn.livechatinc.com" crossorigin />
    <link rel="preconnect" href="https://analytics.tiktok.com" crossorigin />

    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      media="all"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      />
    </noscript>

    <title>{fullTitle}</title>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Stefan Bogdanel",
        "jobTitle": "Senior Software Engineer",
        "url": "https://izdrail.com",
        "image": "https://izdrail.com/og-image.png",
        "sameAs": [
          "https://github.com/izdrail",
          "https://linkedin.com/in/izdrail",
          "https://twitter.com/izdrail"
        ],
        "knowsAbout": [
          "Software Development",
          "Backend Development",
          "Enterprise Software Solutions",
          "E-commerce Applications",
          "Hardware Development",
          "IoT Development",
          "LoRaWAN",
          "AI Development",
          "Large Language Models",
          "Custom AI Agents"
        ],
        "hasOccupation": {
          "@type": "Occupation",
          "name": "Senior Software Engineer",
          "occupationLocation": {
            "@type": "Country",
            "name": "Romania"
          },
          "skills": [
            "PHP",
            "Laravel",
            "JavaScript",
            "TypeScript",
            "Go",
            "C",
            "Python",
            "React",
            "Vue.js",
            "Node.js",
            "Docker",
            "Kubernetes",
            "AWS",
            "PostgreSQL",
            "MySQL",
            "Redis"
          ]
        },
        "alumniOf": {
          "@type": "Organization",
          "name": "Technical University"
        }
      }
    </script>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Stefan Bogdanel - Software Engineering Services",
        "description": "Senior Backend Engineer for hire. Freelance Full Stack Developer & Scalable Systems Consultant. Expert in Custom Software Development & AI Automation.",
        "provider": {
          "@type": "Person",
          "name": "Stefan Bogdanel"
        },
        "areaServed": "Worldwide",
        "serviceType": [
          "Senior Backend Engineer for Hire",
          "Freelance Full Stack Developer",
          "Scalable Systems Consultant",
          "Custom Software Development Services",
          "AI Automation Expert",
          "Backend Development",
          "AI Development",
          "Hardware Development",
          "IoT Solutions"
        ]
      }
    </script>

    <!-- WebSite Schema with Search Action -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Stefan Bogdanel - Senior Software Engineer",
        "url": "https://izdrail.com",
        "description": "Senior Backend Engineer for hire. Freelance Full Stack Developer & Scalable Systems Consultant.",
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://izdrail.com/chat?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }
    </script>

    <!-- FAQ Schema for AI Overviews -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What services does Stefan Bogdanel offer?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Stefan Bogdanel offers Senior Backend Engineering, Freelance Full Stack Development, Scalable Systems Consulting, Custom Software Development, and AI Automation services. He specializes in PHP, Laravel, JavaScript, TypeScript, Go, Python, React, Vue.js, Node.js, Docker, Kubernetes, AWS, and more."
            }
          },
          {
            "@type": "Question",
            "name": "How much does a senior backend engineer cost?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "As a freelance senior backend engineer, Stefan Bogdanel offers competitive rates for custom software development. Contact him for a personalized quote based on your project requirements."
            }
          },
          {
            "@type": "Question",
            "name": "What industries does Stefan Bogdanel work with?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Stefan has experience building solutions for enterprise software, e-commerce applications, CRM systems, IoT/LoRaWAN devices, and AI/LLM infrastructure. He works with both public and private organizations."
            }
          },
          {
            "@type": "Question",
            "name": "How do I hire a senior software engineer?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "To hire a senior software engineer, you can contact Stefan Bogdanel via email at stefan@izdrail.com or through the contact form on his website. He's available for freelance projects and consulting engagements."
            }
          },
          {
            "@type": "Question",
            "name": "What is AI automation and how can it help my business?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "AI automation uses artificial intelligence to streamline business processes, reduce manual work, and increase efficiency. Stefan develops custom LLMs, AI agents, and workflow automation systems tailored to your business needs."
            }
          },
          {
            "@type": "Question",
            "name": "What is the best way to contact Stefan Bogdanel for a project?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "You can reach Stefan Bogdanel by sending an email to stefan@izdrail.com, connecting on LinkedIn, or using the contact form on his website at izdrail.com."
            }
          }
        ]
      }
    </script>

    <!-- BreadcrumbList Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://izdrail.com"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Services",
            "item": "https://izdrail.com/#services"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Chat",
            "item": "https://izdrail.com/chat"
          }
        ]
      }
    </script>

    <!-- HowTo Schema for Services -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to Hire a Senior Software Engineer",
        "description": "A step-by-step guide to hiring a senior software engineer for your project",
        "step": [
          {
            "@type": "HowToStep",
            "name": "1. Define Your Project Requirements",
            "text": "Clearly outline your project goals, technical requirements, timeline, and budget. Determine the specific skills needed (backend, frontend, full stack, AI/ML, etc.)."
          },
          {
            "@type": "HowToStep",
            "name": "2. Research Potential Candidates",
            "text": "Look for experienced senior engineers with proven track records. Check their portfolios, GitHub profiles, LinkedIn, and client testimonials."
          },
          {
            "@type": "HowToStep",
            "name": "3. Contact and Discuss Your Project",
            "text": "Reach out to Stefan Bogdanel at stefan@izdrail.com with your project details. Discuss scope, timeline, and technical requirements."
          },
          {
            "@type": "HowToStep",
            "name": "4. Receive and Review Proposal",
            "text": "Get a detailed proposal including project approach, timeline, cost estimate, and deliverables. Review and ask questions."
          },
          {
            "@type": "HowToStep",
            "name": "5. Start Your Project",
            "text": "Once agreed, begin the project with regular communication, milestone reviews, and iterative development."
          }
        ]
      }
    </script>

    <!-- HowTo Schema for AI Automation -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "HowTo",
        "name": "How to Implement AI Automation in Your Business",
        "description": "A guide to implementing AI automation with custom LLMs and AI agents",
        "step": [
          {
            "@type": "HowToStep",
            "name": "1. Identify Automation Opportunities",
            "text": "Analyze your business processes to identify repetitive tasks, customer service workflows, and data processing operations that could benefit from AI."
          },
          {
            "@type": "HowToStep",
            "name": "2. Define AI Goals",
            "text": "Determine what you want to achieve: cost reduction, faster response times, 24/7 availability, or improved accuracy."
          },
          {
            "@type": "HowToStep",
            "name": "3. Consult with an AI Expert",
            "text": "Contact Stefan Bogdanel to discuss your AI automation needs. He specializes in custom LLMs, AI agents, and LLM infrastructure."
          },
          {
            "@type": "HowToStep",
            "name": "4. Develop Custom AI Solution",
            "text": "Work with your AI developer to build tailored solutions including custom-trained models, agent workflows, and integration with existing systems."
          },
          {
            "@type": "HowToStep",
            "name": "5. Deploy and Monitor",
            "text": "Launch your AI solution and continuously monitor performance, gathering feedback for ongoing optimization."
          }
        ]
      }
    </script>

